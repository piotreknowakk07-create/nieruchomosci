---
import { getCollection } from 'astro:content';
import '../../styles/global.css';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = posts[0];
const rest = posts.slice(1);

function catBg(cat: string) {
  return ['Poradnik','Porównanie','Rynek'].includes(cat) ? '#A67A44' : '#1D3033';
}
function fmtDate(d: Date) {
  return d.toLocaleDateString('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' });
}
---
<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Artykuły i Porady – Skup Nieruchomości Łódź</title>
  <meta name="description" content="Dowiedz się, jak szybko sprzedać mieszkanie w Łodzi. Porady, wycena, gotówka i minimalne formalności – krok po kroku." />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://kupimynieruchomosclodz.pl/artykuly/" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&family=Erode:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- ═══════════════════════════════════════════════════════════
       GOOGLE CONSENT MODE v2 — musi być PIERWSZYM skryptem
       ═══════════════════════════════════════════════════════════ -->
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){ dataLayer.push(arguments); }

    (function () {
      var raw = localStorage.getItem('cm_consent');
      var data = null;
      try { data = raw ? JSON.parse(raw) : null; } catch(e){}
      var valid      = data && data.ts && (Date.now() - data.ts < 365 * 24 * 60 * 60 * 1000);
      var statistics = valid && data.statistics === true;
      var marketing  = valid && data.marketing  === true;

      gtag('consent', 'default', {
        analytics_storage:  statistics ? 'granted' : 'denied',
        ad_storage:         marketing  ? 'granted' : 'denied',
        ad_user_data:       marketing  ? 'granted' : 'denied',
        ad_personalization: marketing  ? 'granted' : 'denied',
        wait_for_update:    500
      });

      window._cmValid = valid;
      window._cmData  = data;
      window._cmStats = statistics;
      window._cmMktg  = marketing;
    })();

    window._gaLoaded = false;
    window.loadGA = function() {
      if (window._gaLoaded) return;
      window._gaLoaded = true;
      var s = document.createElement('script');
      s.async = true;
      s.src = 'https://www.googletagmanager.com/gtag/js?id=G-3R9SGKJGBQ';
      s.onload = function() {
        gtag('js', new Date());
        gtag('config', 'G-3R9SGKJGBQ');
      };
      document.head.appendChild(s);
    };

    if (window._cmValid && window._cmStats) {
      window.loadGA();
    }
  </script>
</head>
<body class="bg-white text-gray-800">

  <header class="fixed top-0 left-0 right-0 z-50 border-b border-white/10 backdrop-blur-sm" style="background: rgba(38,58,62,0.97); box-shadow: 0 1px 0 rgba(0,0,0,0.15), 0 4px 16px rgba(0,0,0,0.12);">
    <div class="max-w-6xl mx-auto px-6 flex items-center justify-between h-16">
      <a href="/" class="block">
        <span style="font-family: 'Erode', serif; font-size: clamp(18px, 4.5vw, 30px); font-weight: 600; color: white; letter-spacing: 0.01em; white-space: nowrap;">SKUP NIERUCHOMOŚCI</span>
      </a>
      <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-white/70">
        <a href="/#o-nas">O nas</a>
        <a href="/#o-nas">Usługi</a>
        <a href="/#jak-dziala">Jak to działa</a>
        <a href="/#faq">Najczęstsze pytania</a>
        <a href="/artykuly/">Artykuły</a>
        <a href="/#kontakt" class="btn-primary px-5 py-2 rounded-lg text-sm font-semibold" style="color: white;">Bezpłatna wycena</a>
      </nav>
      <button id="menu-toggle" aria-expanded="false" aria-controls="mobile-menu" aria-label="Menu" class="md:hidden p-2 rounded-lg">
        <span class="ham-line ham-line-1"></span>
        <span class="ham-line ham-line-2"></span>
        <span class="ham-line ham-line-3"></span>
      </button>
    </div>
  </header>

  <div id="mobile-menu" role="navigation" aria-label="Menu mobilne">
    <a href="/#o-nas">O nas</a>
    <a href="/#o-nas">Usługi</a>
    <a href="/#jak-dziala">Jak to działa</a>
    <a href="/#faq">Najczęstsze pytania</a>
    <a href="/artykuly/">Artykuły</a>
    <a href="/#kontakt" class="mobile-cta">Bezpłatna wycena →</a>
  </div>

  <script>
    (function() {
      var btn = document.getElementById('menu-toggle');
      var menu = document.getElementById('mobile-menu');
      function closeMenu() { menu.classList.remove('open'); btn.setAttribute('aria-expanded','false'); document.removeEventListener('click', outsideClick); }
      function outsideClick(e) { if (!menu.contains(e.target) && !btn.contains(e.target)) closeMenu(); }
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var isOpen = menu.classList.toggle('open');
        btn.setAttribute('aria-expanded', String(isOpen));
        if (isOpen) { setTimeout(function() { document.addEventListener('click', outsideClick); }, 10); } else { document.removeEventListener('click', outsideClick); }
      });
      menu.querySelectorAll('a').forEach(function(link) { link.addEventListener('click', closeMenu); });
      function positionMenu() { var h = document.querySelector('header'); if (h) menu.style.top = h.offsetHeight + 'px'; }
      positionMenu(); window.addEventListener('resize', positionMenu);
    })();
  </script>

  <section class="pt-32 pb-16 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      <nav class="flex items-center gap-2 text-sm text-gray-400 mb-8">
        <a href="/" class="hover:text-brand-orange transition-colors">Strona główna</a>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <span class="text-gray-600">Artykuły</span>
      </nav>
      <p class="text-brand-orange font-semibold text-sm uppercase tracking-widest mb-3">Wiedza i porady</p>
      <h1 class="font-serif font-bold text-brand-dark mb-5" style="letter-spacing: -0.02em; font-size: clamp(1.6rem, 7vw, 3rem);">Artykuły o nieruchomościach</h1>
      <p class="text-gray-500 text-lg max-w-2xl" style="line-height: 1.75;">Praktyczne porady dotyczące sprzedaży mieszkań, skupu nieruchomości i rynku w Łodzi. Dowiedz się jak przygotować się do sprzedaży.</p>
    </div>
  </section>

  <section class="pb-24 bg-white">
    <div class="max-w-6xl mx-auto px-6">

      {featured && (
        <a href={`/artykuly/${featured.id}`} class="card-article block rounded-2xl overflow-hidden border border-gray-100 shadow-card mb-12 grid md:grid-cols-2">
          <div class="relative overflow-hidden h-64 md:h-auto">
            <img src={featured.data.heroImage} alt={featured.data.title} class="card-img w-full h-full object-cover" style={featured.data.heroImagePosition ? `object-position: ${featured.data.heroImagePosition};` : ''} />
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(29,48,51,0.6) 0%, transparent 60%);"></div>
            <span class="absolute top-4 left-4 text-white text-xs font-semibold px-3 py-1 rounded-full" style={`background:${catBg(featured.data.category)}`}>{featured.data.category}</span>
          </div>
          <div class="p-8 md:p-10 flex flex-col justify-center">
            <p class="text-brand-orange text-xs font-semibold uppercase tracking-widest mb-3">{fmtDate(featured.data.pubDate)} · {featured.data.readTime} czytania</p>
            <h2 class="text-3xl font-serif font-bold text-brand-dark mb-4" style="letter-spacing: -0.02em;">{featured.data.title}</h2>
            <p class="text-gray-500 leading-relaxed mb-6" style="line-height: 1.75;">{featured.data.excerpt}</p>
            <span class="inline-flex items-center gap-2 text-brand-orange font-semibold text-sm">
              Czytaj więcej
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
        </a>
      )}

      {rest.length > 0 && (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {rest.map((p) => (
            <a href={`/artykuly/${p.id}`} class="card-article block rounded-2xl overflow-hidden border border-gray-100 shadow-card">
              <div class="relative overflow-hidden h-48">
                <img src={p.data.heroImage} alt={p.data.title} class="card-img w-full h-full object-cover" />
                <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(29,48,51,0.5) 0%, transparent 60%);"></div>
                <span class="absolute top-3 left-3 text-white text-xs font-semibold px-2.5 py-1 rounded-full" style={`background:${catBg(p.data.category)}`}>{p.data.category}</span>
              </div>
              <div class="p-6">
                <p class="text-gray-400 text-xs mb-2">{fmtDate(p.data.pubDate)} · {p.data.readTime}</p>
                <h3 class="font-serif font-bold text-brand-dark text-xl mb-3" style="letter-spacing:-0.01em;">{p.data.title}</h3>
                <p class="text-gray-500 text-sm leading-relaxed mb-4" style="line-height:1.7;">{p.data.excerpt}</p>
                <span class="inline-flex items-center gap-1.5 text-brand-orange font-semibold text-sm">
                  Czytaj więcej <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      )}

    </div>
  </section>

  <footer class="py-12 border-t border-white/10" style="background:#1D3033;">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <span style="font-family:'Erode',serif;font-size:30px;font-weight:600;color:white;letter-spacing:0.01em;">SKUP NIERUCHOMOŚCI</span>
        <p class="text-white/40 text-sm text-center">© 2026 Skup Nieruchomości Łódź. Wszelkie prawa zastrzeżone.</p>
        <nav class="flex gap-6 text-sm text-white/60">
          <a href="/#o-nas" class="hover:text-brand-orange transition-colors">O nas</a>
          <a href="/#uslugi" class="hover:text-brand-orange transition-colors">Usługi</a>
          <a href="/#kontakt" class="hover:text-brand-orange transition-colors">Kontakt</a>
        </nav>
      </div>
    </div>
  </footer>

  <!-- =====================================================
       COOKIE CONSENT BANNER — GA4: G-3R9SGKJGBQ
       ===================================================== -->
  <style>
    #cookie-banner {
      position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(120px);
      z-index: 99999; width: calc(100% - 32px); max-width: 680px; background: #1D3033;
      border-radius: 20px; padding: 20px 24px;
      box-shadow: 0 8px 40px rgba(0,0,0,0.35), 0 2px 8px rgba(0,0,0,0.15);
      display: flex; align-items: center; gap: 20px;
      opacity: 0; transition: transform 0.5s cubic-bezier(0.22,1,0.36,1), opacity 0.4s ease; pointer-events: none;
    }
    #cookie-banner.visible { transform: translateX(-50%) translateY(0); opacity: 1; pointer-events: auto; }
    #cookie-banner p { color: rgba(255,255,255,0.75); font-size: 0.8125rem; line-height: 1.6; margin: 0; flex: 1; }
    #cookie-banner a { color: #B8914F; text-decoration: underline; }
    #cookie-banner a:hover { color: #A67A44; }
    .cookie-btn { border: none; border-radius: 12px; font-size: 0.8125rem; font-weight: 600; cursor: pointer; padding: 10px 20px; white-space: nowrap; transition: transform 0.2s cubic-bezier(0.22,1,0.36,1), opacity 0.2s; flex-shrink: 0; }
    .cookie-btn:hover  { transform: translateY(-1px); opacity: 0.9; }
    .cookie-btn:active { transform: translateY(0); }
    #cookie-accept { background: linear-gradient(135deg, #A67A44, #B8914F); color: #fff; }
    #cookie-reject { background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.9); border: 1px solid rgba(255,255,255,0.2); }
    #cookie-customize { background: transparent; color: rgba(255,255,255,0.5); padding: 10px 14px; border: 1px solid rgba(255,255,255,0.12); font-weight: 400; font-size: 0.75rem; }
    @media (max-width: 540px) { #cookie-banner { flex-direction: column; align-items: stretch; gap: 12px; } .cookie-btn { text-align: center; } }
    #cookie-modal-overlay { position: fixed; inset: 0; z-index: 999999; background: rgba(0,0,0,0.55); backdrop-filter: blur(4px); display: flex; align-items: flex-end; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.3s ease; }
    #cookie-modal-overlay.visible { opacity: 1; pointer-events: auto; }
    #cookie-modal { background: #fff; width: 100%; max-width: 520px; border-radius: 24px 24px 0 0; padding: 32px 28px 36px; transform: translateY(40px); transition: transform 0.4s cubic-bezier(0.22,1,0.36,1); max-height: 90vh; overflow-y: auto; }
    #cookie-modal-overlay.visible #cookie-modal { transform: translateY(0); }
    @media (min-width: 560px) { #cookie-modal-overlay { align-items: center; } #cookie-modal { border-radius: 24px; } }
    .cm-title { font-family: 'Playfair Display', serif; font-size: 1.25rem; font-weight: 700; color: #1D3033; margin: 0 0 6px; }
    .cm-subtitle { font-size: 0.8125rem; color: #6b7280; line-height: 1.6; margin: 0 0 24px; }
    .cm-subtitle a { color: #A67A44; text-decoration: underline; }
    .cm-row { display: flex; align-items: flex-start; gap: 16px; padding: 16px 0; border-bottom: 1px solid #f3f4f6; }
    .cm-row:last-of-type { border-bottom: none; }
    .cm-row-text { flex: 1; }
    .cm-row-name { font-size: 0.875rem; font-weight: 600; color: #1D3033; margin: 0 0 3px; }
    .cm-row-desc { font-size: 0.78rem; color: #9ca3af; line-height: 1.55; margin: 0; }
    .cm-toggle { position: relative; flex-shrink: 0; margin-top: 2px; }
    .cm-toggle input { opacity: 0; width: 0; height: 0; position: absolute; }
    .cm-toggle-track { display: block; width: 44px; height: 24px; border-radius: 100px; background: #e5e7eb; cursor: pointer; transition: background 0.25s; position: relative; }
    .cm-toggle input:checked + .cm-toggle-track { background: linear-gradient(135deg, #A67A44, #B8914F); }
    .cm-toggle input:disabled + .cm-toggle-track { cursor: not-allowed; opacity: 0.6; }
    .cm-toggle-track::after { content: ''; position: absolute; top: 3px; left: 3px; width: 18px; height: 18px; border-radius: 50%; background: #fff; box-shadow: 0 1px 4px rgba(0,0,0,0.18); transition: transform 0.25s cubic-bezier(0.22,1,0.36,1); }
    .cm-toggle input:checked + .cm-toggle-track::after { transform: translateX(20px); }
    .cm-actions { display: flex; gap: 10px; margin-top: 24px; }
    .cm-btn { flex: 1; border: none; border-radius: 12px; font-size: 0.875rem; font-weight: 600; padding: 12px 16px; cursor: pointer; transition: transform 0.2s cubic-bezier(0.22,1,0.36,1), opacity 0.2s; }
    .cm-btn:hover  { transform: translateY(-1px); opacity: 0.9; }
    .cm-btn:active { transform: translateY(0); }
    #cm-save { background: linear-gradient(135deg, #A67A44, #B8914F); color: #fff; }
    #cm-reject-all { background: #f3f4f6; color: #6b7280; }
  </style>

  <div id="cookie-banner" role="dialog" aria-label="Zgoda na pliki cookie">
    <p>Używamy plików cookie do celów statystycznych i marketingowych. Możesz wybrać, które akceptujesz. <a href="/privacy.html">Polityka prywatności</a></p>
    <button class="cookie-btn" id="cookie-customize">Personalizuj</button>
    <button class="cookie-btn" id="cookie-reject">Odrzuć wszystkie</button>
    <button class="cookie-btn" id="cookie-accept">Akceptuj wszystkie</button>
  </div>

  <div id="cookie-modal-overlay" role="dialog" aria-modal="true" aria-label="Ustawienia cookies">
    <div id="cookie-modal">
      <p class="cm-title">Ustawienia prywatności</p>
      <p class="cm-subtitle">Wybierz, które pliki cookie chcesz zaakceptować. <a href="/privacy.html">Polityka prywatności</a></p>
      <div class="cm-row">
        <div class="cm-row-text"><p class="cm-row-name">Niezbędne</p><p class="cm-row-desc">Wymagane do działania strony (sesja, formularz). Nie można ich wyłączyć.</p></div>
        <label class="cm-toggle"><input type="checkbox" checked disabled><span class="cm-toggle-track"></span></label>
      </div>
      <div class="cm-row">
        <div class="cm-row-text"><p class="cm-row-name">Statystyki</p><p class="cm-row-desc">Google Analytics — mierzą ruch i zachowanie użytkowników. Dane są anonimizowane i nie identyfikują osobiście.</p></div>
        <label class="cm-toggle"><input type="checkbox" id="toggle-statistics"><span class="cm-toggle-track"></span></label>
      </div>
      <div class="cm-row">
        <div class="cm-row-text"><p class="cm-row-name">Marketing</p><p class="cm-row-desc">Google Ads / remarketing — pozwalają wyświetlać dopasowane reklamy. Twoje dane mogą być przekazywane partnerom reklamowym.</p></div>
        <label class="cm-toggle"><input type="checkbox" id="toggle-marketing"><span class="cm-toggle-track"></span></label>
      </div>
      <div class="cm-actions">
        <button class="cm-btn" id="cm-reject-all">Odrzuć wszystkie</button>
        <button class="cm-btn" id="cm-save">Zapisz ustawienia</button>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      function saveConsent(statistics, marketing) {
        localStorage.setItem('cm_consent', JSON.stringify({ necessary: true, statistics: statistics, marketing: marketing, ts: Date.now(), version: '1.0' }));
      }
      function applyConsent(statistics, marketing) {
        gtag('consent', 'update', {
          analytics_storage:  statistics ? 'granted' : 'denied',
          ad_storage:         marketing  ? 'granted' : 'denied',
          ad_user_data:       marketing  ? 'granted' : 'denied',
          ad_personalization: marketing  ? 'granted' : 'denied'
        });
        if (statistics && typeof window.loadGA === 'function') { window.loadGA(); }
        if (!statistics || !marketing) {
          document.cookie.split(';').forEach(function (c) {
            var name = c.trim().split('=')[0];
            if (/^(_ga|_gid|_gat|_gcl|_gac)/.test(name)) {
              document.cookie = name + '=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/; domain=' + location.hostname;
              document.cookie = name + '=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/; domain=.' + location.hostname;
            }
          });
        }
      }
      function hideBanner() {
        var b = document.getElementById('cookie-banner');
        if (!b) return;
        b.style.opacity = '0';
        b.style.transform = 'translateX(-50%) translateY(120px)';
        setTimeout(function () { b.remove(); }, 500);
      }
      function closeModal() { document.getElementById('cookie-modal-overlay').classList.remove('visible'); }

      if (window._cmValid) {
        var d = window._cmData;
        if (d) {
          var togS = document.getElementById('toggle-statistics');
          var togM = document.getElementById('toggle-marketing');
          if (togS) togS.checked = !!d.statistics;
          if (togM) togM.checked = !!d.marketing;
        }
        return;
      }

      setTimeout(function () {
        var banner = document.getElementById('cookie-banner');
        if (banner) banner.classList.add('visible');
      }, 800);

      document.getElementById('cookie-accept').addEventListener('click', function () { saveConsent(true, true); applyConsent(true, true); hideBanner(); });
      document.getElementById('cookie-reject').addEventListener('click', function () { saveConsent(false, false); applyConsent(false, false); hideBanner(); });
      document.getElementById('cookie-customize').addEventListener('click', function () { document.getElementById('cookie-modal-overlay').classList.add('visible'); });
      document.getElementById('cookie-modal-overlay').addEventListener('click', function (e) { if (e.target === this) closeModal(); });
      document.getElementById('cm-save').addEventListener('click', function () {
        var s = document.getElementById('toggle-statistics').checked;
        var m = document.getElementById('toggle-marketing').checked;
        saveConsent(s, m); applyConsent(s, m); closeModal(); hideBanner();
      });
      document.getElementById('cm-reject-all').addEventListener('click', function () { saveConsent(false, false); applyConsent(false, false); closeModal(); hideBanner(); });
    })();
  </script>
</body>
</html>
