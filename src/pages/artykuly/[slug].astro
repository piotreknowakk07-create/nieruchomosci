        <div class="flex items-center gap-3 mb-4">
          <span class="text-white text-xs font-semibold px-3 py-1 rounded-full" style={`background:${categoryBg}`}>{category}</span>
          <span class="text-white/60 text-sm">{dateStr} · {readTime} czytania</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-serif font-bold text-white leading-tight" style="letter-spacing:-0.02em;">{title}</h1>
      </div>
    </div>
  </div>

  <div class="py-10 px-6" style="max-width: 1400px; margin: 0 auto;">
    <div class="lg:grid lg:gap-16" style="grid-template-columns: 1fr min(52rem, 100%) 340px;">

      <div class="hidden lg:block"></div>

      <article class="min-w-0">

        <!-- CTA mobilne — widoczne tylko na telefonie, na górze artykułu -->
        <div class="lg:hidden mb-8">
          <a href="/#kontakt" class="cta-inline-mobile">Wyceń swoją nieruchomość za darmo</a>
        </div>

        <nav class="flex items-center gap-2 text-sm text-gray-400 mb-10">
          <a href="/" class="hover:text-brand-orange transition-colors">Strona główna</a>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          <a href="/artykuly/" class="hover:text-brand-orange transition-colors">Artykuły</a>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          <span class="text-gray-600 truncate max-w-xs">{title.length > 40 ? title.slice(0,40) + '...' : title}</span>
        </nav>

        <div class="prose" id="article-prose">
          <Content />
        </div>

        <script is:inline>
          (function() {
            var prose = document.getElementById('article-prose');
            if (!prose) return;
            var children = Array.from(prose.children);
            var mid = Math.floor(children.length / 2);
            var cta = document.createElement('div');
            cta.className = 'cta-inline';
            cta.innerHTML = '<a href="/#kontakt">Wyceń nieruchomość za darmo!</a>';
            if (children[mid]) {
              prose.insertBefore(cta, children[mid]);
            } else {
              prose.appendChild(cta);
            }
          })();
        </script>

        <div class="my-14 rounded-2xl p-10 text-center relative overflow-hidden" style="background:linear-gradient(135deg,#1D3033 0%,#243B41 100%);">
          <div class="absolute -top-16 -right-16 w-64 h-64 rounded-full opacity-10" style="background:radial-gradient(circle,#A67A44,transparent);"></div>
