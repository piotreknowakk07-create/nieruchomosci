---
import { getCollection, render } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, category, readTime, heroImage, heroImagePosition, excerpt } = post.data;

const allPosts = await getCollection('blog');
const otherPosts = allPosts.filter((p) => p.id !== post.id).slice(0, 3);

const dateStr = pubDate.toLocaleDateString('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' });
const categoryBg = category === 'Poradnik' || category === 'Porównanie' || category === 'Rynek' ? '#A67A44' : '#1D3033';
---
<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} – Skup Nieruchomości Łódź</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={`https://kupimynieruchomosclodz.pl/artykuly/${post.id}`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="article" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&family=Erode:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="bg-white text-gray-800">

  <header class="fixed top-0 left-0 right-0 z-50 border-b border-white/10 backdrop-blur-sm" style="background: rgba(38,58,62,0.97); box-shadow: 0 1px 0 rgba(0,0,0,0.15), 0 4px 16px rgba(0,0,0,0.12);">
    <div class="max-w-6xl mx-auto px-6 flex items-center justify-between h-16">
      <a href="/" class="block">
        <span style="font-family: 'Erode', serif; font-size: clamp(18px, 4.5vw, 30px); font-weight: 600; color: white; letter-spacing: 0.01em; white-space: nowrap;">SKUP NIERUCHOMOŚCI</span>
      </a>
      <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-white/70">
        <a href="/#o-nas">O nas</a>
        <a href="/#o-nas">Usługi</a>
        <a href="/#jak-dziala">Jak to działa</a>
        <a href="/#faq">Najczęstsze pytania</a>
        <a href="/artykuly/">Artykuły</a>
        <a href="/#kontakt" class="btn-primary px-5 py-2 rounded-lg text-sm font-semibold" style="color: white;">Bezpłatna wycena</a>
      </nav>
      <button id="menu-toggle" aria-expanded="false" aria-controls="mobile-menu" aria-label="Menu" class="md:hidden p-2 rounded-lg">
        <span class="ham-line ham-line-1"></span>
        <span class="ham-line ham-line-2"></span>
        <span class="ham-line ham-line-3"></span>
      </button>
    </div>
  </header>

  <div id="mobile-menu" role="navigation" aria-label="Menu mobilne">
    <a href="/#o-nas">O nas</a>
    <a href="/#o-nas">Usługi</a>
    <a href="/#jak-dziala">Jak to działa</a>
    <a href="/#faq">Najczęstsze pytania</a>
    <a href="/artykuly/">Artykuły</a>
    <a href="/#kontakt" class="mobile-cta">Bezpłatna wycena →</a>
  </div>

  <script>
    (function() {
      var btn = document.getElementById('menu-toggle');
      var menu = document.getElementById('mobile-menu');
      function closeMenu() { menu.classList.remove('open'); btn.setAttribute('aria-expanded','false'); document.removeEventListener('click', outsideClick); }
      function outsideClick(e) { if (!menu.contains(e.target) && !btn.contains(e.target)) closeMenu(); }
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var isOpen = menu.classList.toggle('open');
        btn.setAttribute('aria-expanded', String(isOpen));
        if (isOpen) { setTimeout(function() { document.addEventListener('click', outsideClick); }, 10); } else { document.removeEventListener('click', outsideClick); }
      });
      menu.querySelectorAll('a').forEach(function(link) { link.addEventListener('click', closeMenu); });
      function positionMenu() { var h = document.querySelector('header'); if (h) menu.style.top = h.offsetHeight + 'px'; }
      positionMenu(); window.addEventListener('resize', positionMenu);
    })();

    // Sidebar consent checkbox visual
    (function() {
      var cb = document.getElementById('sidebar-consent');
      var box = document.getElementById('sidebar-consent-box');
      var check = document.getElementById('sidebar-consent-check');
      if (!cb || !box || !check) return;
      cb.addEventListener('change', function() {
        if (this.checked) {
          box.style.background = '#A67A44';
          box.style.borderColor = '#A67A44';
          check.style.display = 'block';
        } else {
          box.style.background = 'rgba(255,255,255,0.07)';
          box.style.borderColor = 'rgba(255,255,255,0.3)';
          check.style.display = 'none';
        }
      });
    })();
  </script>

  <div class="relative w-full h-[60vh] min-h-[400px] overflow-hidden">
    <img src={heroImage} alt={title} class="w-full h-full object-cover" style={heroImagePosition ? `object-position: ${heroImagePosition};` : ''} />
    <div class="absolute inset-0" style="background:linear-gradient(to top,rgba(29,48,51,0.75) 0%,rgba(29,48,51,0.2) 60%,transparent 100%);"></div>
    <div class="absolute bottom-0 left-0 right-0 pb-10 pt-20" style="background:linear-gradient(to top,rgba(29,48,51,0.8),transparent);">
      <div class="max-w-3xl mx-auto px-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-white text-xs font-semibold px-3 py-1 rounded-full" style={`background:${categoryBg}`}>{category}</span>
          <span class="text-white/60 text-sm">{dateStr} · {readTime} czytania</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-serif font-bold text-white leading-tight" style="letter-spacing:-0.02em;">{title}</h1>
      </div>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-6 py-10">
    <div class="flex gap-10 xl:gap-16 items-start">

      <article class="flex-1 min-w-0">
        <nav class="flex items-center gap-2 text-sm text-gray-400 mb-10">
          <a href="/" class="hover:text-brand-orange transition-colors">Strona główna</a>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          <a href="/artykuly/" class="hover:text-brand-orange transition-colors">Artykuły</a>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          <span class="text-gray-600 truncate max-w-xs">{title.length > 40 ? title.slice(0,40) + '...' : title}</span>
        </nav>

        <div class="prose" id="article-prose">
          <Content />
        </div>

        <script is:inline>
          (function() {
            var prose = document.getElementById('article-prose');
            if (!prose) return;
            var children = Array.from(prose.children);
            var mid = Math.floor(children.length / 2);
            var cta = document.createElement('div');
            cta.className = 'cta-inline';
            cta.innerHTML = '<a href="/#kontakt">Wyceń nieruchomość za darmo!</a>';
            if (children[mid]) {
              prose.insertBefore(cta, children[mid]);
            } else {
              prose.appendChild(cta);
            }
          })();
        </script>

        <div class="my-14 rounded-2xl p-10 text-center relative overflow-hidden" style="background:linear-gradient(135deg,#1D3033 0%,#243B41 100%);">
          <div class="absolute -top-16 -right-16 w-64 h-64 rounded-full opacity-10" style="background:radial-gradient(circle,#A67A44,transparent);"></div>
          <p class="text-white/60 text-sm uppercase tracking-widest font-semibold mb-3">Bezpłatna konsultacja</p>
          <h2 class="text-3xl font-serif font-bold text-white mb-4" style="letter-spacing:-0.02em;">Chcesz sprzedać mieszkanie szybko?</h2>
          <p class="text-white/70 mb-8 max-w-md mx-auto" style="line-height:1.75;">Skontaktuj się z nami – wycenimy Twoją nieruchomość bezpłatnie i bez zobowiązań w ciągu 24 godzin.</p>
          <a href="/#kontakt" class="btn-primary inline-block text-white px-10 py-4 rounded-xl font-semibold text-base" style="box-shadow:0 8px 24px rgba(166,122,68,0.35);">Uzyskaj bezpłatną wycenę</a>
        </div>
      </article>

      <!-- STICKY SIDEBAR -->
      <aside class="hidden lg:block w-[300px] flex-shrink-0">
        <div id="article-sidebar" style="position: sticky; top: 88px;">
          <div class="shadow-sidebar rounded-2xl overflow-hidden">
            <div style="height:4px; background:linear-gradient(90deg,#A67A44,#B8914F);"></div>
            <div style="background:linear-gradient(160deg,#1D3033 0%,#243B41 100%); padding:28px;">
              <div style="display:flex; align-items:center; gap:14px; margin-bottom:20px;">
                <div style="width:48px; height:48px; border-radius:50%; background:linear-gradient(135deg,#A67A44,#B8914F); display:flex; align-items:center; justify-content:center; font-family:'Playfair Display',Georgia,serif; font-size:20px; font-weight:700; color:white; flex-shrink:0;">P</div>
                <div>
                  <p style="color:white; font-weight:600; font-size:15px; margin:0 0 2px;">Piotrek</p>
                  <p style="color:rgba(255,255,255,0.42); font-size:12px; margin:0;">Specjalista ds. skupu nieruchomości</p>
                </div>
              </div>
              <h3 style="font-family:'Playfair Display',Georgia,serif; color:white; font-size:1.2rem; font-weight:700; letter-spacing:-0.01em; margin:0 0 7px;">Darmowa wycena</h3>
              <p style="color:rgba(255,255,255,0.52); font-size:13.5px; line-height:1.65; margin:0 0 20px;">Skontaktuj się ze mną – odpiszę w&nbsp;ciągu 24&nbsp;godzin.</p>
              <a href="tel:+48739503924" id="sidebar-phone" style="display:flex; align-items:center; gap:12px; margin-bottom:20px; text-decoration:none;">
                <div style="width:40px; height:40px; border-radius:12px; background:rgba(166,122,68,0.18); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                  <svg width="18" height="18" fill="none" stroke="#A67A44" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <p style="color:rgba(255,255,255,0.42); font-size:11px; margin:0 0 2px; text-transform:uppercase; letter-spacing:0.06em;">Zadzwoń teraz</p>
                  <p class="sidebar-phone-num" style="color:white; font-weight:600; font-size:15px; margin:0; transition:color 0.2s;">+48 739 503 924</p>
                </div>
              </a>
              <div style="height:1px; background:rgba(255,255,255,0.1); margin-bottom:20px;"></div>
              <form id="sidebar-form">
                <div style="margin-bottom:10px;">
                  <input type="text" name="imie" placeholder="Imię i nazwisko" required class="sidebar-input"
                    style="display:block; width:100%; padding:11px 14px; border-radius:10px; background:rgba(255,255,255,0.07); border:1.5px solid rgba(255,255,255,0.12); color:white; font-size:13.5px; font-family:'Inter',sans-serif; transition:border-color 0.2s;" />
                </div>
                <div style="margin-bottom:10px;">
                  <input type="tel" name="telefon" placeholder="Numer telefonu" required class="sidebar-input"
                    style="display:block; width:100%; padding:11px 14px; border-radius:10px; background:rgba(255,255,255,0.07); border:1.5px solid rgba(255,255,255,0.12); color:white; font-size:13.5px; font-family:'Inter',sans-serif; transition:border-color 0.2s;" />
                </div>
                <div style="margin-bottom:14px;">
                  <label style="display:flex; align-items:flex-start; gap:10px; cursor:pointer;">
                    <span style="position:relative; margin-top:2px; flex-shrink:0; width:18px; height:18px;">
                      <input type="checkbox" name="zgoda" required id="sidebar-consent"
                        style="position:absolute; opacity:0; width:0; height:0;" />
                      <span id="sidebar-consent-box" style="display:block; width:18px; height:18px; border-radius:5px; border:1.5px solid rgba(255,255,255,0.3); background:rgba(255,255,255,0.07); transition:background 0.15s, border-color 0.15s;"></span>
                      <svg id="sidebar-consent-check" style="position:absolute; inset:0; width:18px; height:18px; pointer-events:none; display:none;" viewBox="0 0 20 20" fill="none">
                        <path d="M5 10l3.5 3.5L15 7" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                    <span style="color:rgba(255,255,255,0.48); font-size:11.5px; line-height:1.6; font-family:'Inter',sans-serif;">
                      <span style="color:#f87171;">*</span> Zapoznałem/-am się z <a href="/privacy.html" style="color:rgba(255,255,255,0.65); text-decoration:underline;">Polityką Prywatności</a> i wyrażam zgodę na przetwarzanie moich danych osobowych.
                    </span>
                  </label>
                  <p id="sidebar-consent-error" style="display:none; color:#f87171; font-size:11px; margin-top:4px; margin-left:28px; font-family:'Inter',sans-serif;">Ta zgoda jest wymagana.</p>
                </div>
                <button type="submit" id="sidebar-btn"
                  style="display:block; width:100%; padding:13px; border-radius:10px; background:linear-gradient(135deg,#A67A44,#B8914F); color:white; font-weight:600; font-size:14px; font-family:'Inter',sans-serif; cursor:pointer; border:none;">
                  Wyślij zapytanie →
                </button>
                <p id="sidebar-success" style="display:none; text-align:center; color:#6ee7b7; font-size:13px; margin-top:10px; font-family:'Inter',sans-serif;">✓ Dziękujemy! Odezwiemy się wkrótce.</p>
              </form>
            </div>
          </div>
        </div>
      </aside>

    </div><!-- /flex -->
  </div><!-- /max-w-6xl -->

  {otherPosts.length > 0 && (
    <section class="pb-24 border-t border-gray-100">
      <div class="max-w-6xl mx-auto px-6 pt-16">
        <h2 class="text-3xl font-serif font-bold text-brand-dark mb-10" style="letter-spacing:-0.02em;">Inne artykuły</h2>
        <div class="grid md:grid-cols-3 gap-8">
          {otherPosts.map((p) => {
            const bg = p.data.category === 'Poradnik' || p.data.category === 'Porównanie' || p.data.category === 'Rynek' ? '#A67A44' : '#1D3033';
            const d = p.data.pubDate.toLocaleDateString('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' });
            return (
              <a href={`/artykuly/${p.id}`} class="card-article block rounded-2xl overflow-hidden border border-gray-100 shadow-card">
                <div class="relative overflow-hidden h-48">
                  <img src={p.data.heroImage} alt={p.data.title} class="card-img w-full h-full object-cover" />
                  <div class="absolute inset-0" style="background:linear-gradient(to top,rgba(29,48,51,0.5) 0%,transparent 60%);"></div>
                  <span class="absolute top-3 left-3 text-white text-xs font-semibold px-2.5 py-1 rounded-full" style={`background:${bg}`}>{p.data.category}</span>
                </div>
                <div class="p-6">
                  <p class="text-gray-400 text-xs mb-2">{d} · {p.data.readTime}</p>
                  <h3 class="font-serif font-bold text-brand-dark text-lg mb-2">{p.data.title}</h3>
                  <span class="inline-flex items-center gap-1.5 text-brand-orange font-semibold text-sm">Czytaj więcej <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg></span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <script is:inline>
    (function() {
      var FORMSPREE = 'https://formspree.io/f/xvzvrkrp';
      var form = document.getElementById('sidebar-form');
      if (!form) return;
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        var btn = document.getElementById('sidebar-btn');
        var nameVal  = form.querySelector('[name="imie"]').value.trim();
        var phoneVal = form.querySelector('[name="telefon"]').value.trim();
        var msgVal   = form.querySelector('[name="wiadomosc"]').value;
        var consentEl = form.querySelector('[name="zgoda"]');
        var consentOk = consentEl && consentEl.checked;
        var consentErr = document.getElementById('sidebar-consent-error');
        if (consentErr) consentErr.style.display = consentOk ? 'none' : 'block';
        if (!nameVal || !phoneVal || !consentOk) return;
        btn.textContent = 'Wysyłanie...';
        btn.disabled = true;
        try {
          var res = await fetch(FORMSPREE, {
            method: 'POST',
            headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
            body: JSON.stringify({ imie: nameVal, telefon: phoneVal, wiadomosc: msgVal })
          });
          if (res.ok) {
            form.reset();
            document.getElementById('sidebar-success').style.display = 'block';
          } else {
            btn.textContent = 'Błąd – spróbuj ponownie';
            btn.disabled = false;
          }
        } catch(err) {
          btn.textContent = 'Błąd – spróbuj ponownie';
          btn.disabled = false;
        }
      });
    })();
  </script>

  <footer class="py-12 border-t border-white/10" style="background:#1D3033;">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <span style="font-family:'Erode',serif;font-size:30px;font-weight:600;color:white;letter-spacing:0.01em;">SKUP NIERUCHOMOŚCI</span>
        <p class="text-white/40 text-sm text-center">© 2026 Skup Nieruchomości Łódź. Wszelkie prawa zastrzeżone.</p>
        <nav class="flex gap-6 text-sm text-white/60">
          <a href="/#o-nas" class="hover:text-brand-orange transition-colors">O nas</a>
          <a href="/#uslugi" class="hover:text-brand-orange transition-colors">Usługi</a>
          <a href="/#kontakt" class="hover:text-brand-orange transition-colors">Kontakt</a>
        </nav>
      </div>
    </div>
  </footer>
</body>
</html>
